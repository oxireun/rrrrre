local CurrentGameTabToken = 0
local GamesLoaded = false
local IsGamesScanning = false

local function LoadGamesData(forceRefresh)
	if GamesLoaded and not forceRefresh then return end
	if IsGamesScanning then return end
	IsGamesScanning = true
	GamesLoaded = true

	CurrentGameTabToken = CurrentGameTabToken + 1
	local myToken = CurrentGameTabToken

	GamesRefreshBtn.Text = "Scanning..."
	for _, v in pairs(GamesScrollContainer:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
	GamesStatusText.Text = "Fetching Portals & Games..."
	GamesStatusText.Visible = true

	task.spawn(function()
		local placeIdsToProcess = {}
		local addedPlaces = {}

		local function addPlace(pId, isTrusted)
			if not addedPlaces[pId] then
				addedPlaces[pId] = true
				table.insert(placeIdsToProcess, {id = pId, trusted = isTrusted})
			end
		end

		local url = "https://develop.roproxy.com/v1/universes/" .. game.GameId .. "/places?isUniverseCreation=false&limit=100&sortOrder=Asc"
		local s, res = pcall(function() return game:HttpGet(url) end)
		if s and res then
			local ds, decoded = pcall(function() return HttpService:JSONDecode(res) end)
			if ds and decoded and decoded.data then
				for _, placeInfo in pairs(decoded.data) do
					addPlace(placeInfo.id, true)
				end
			end
		end

		for pId, _ in pairs(CapturedPortals) do
			addPlace(pId, true)
		end

		local inGameNums = CollectInGameNumbers()
		for pId, _ in pairs(inGameNums) do
			addPlace(pId, false)
		end

		local count = 0

		for _, data in ipairs(placeIdsToProcess) do
			task.spawn(function()
				if CurrentGameTabToken ~= myToken then return end
				
				local pId = data.id
				local success, info = pcall(function() return MarketplaceService:GetProductInfo(pId, Enum.InfoType.Asset) end)
				
				if success and info and info.AssetTypeId == 9 then
					local isValid = false
					
					if data.trusted then
						isValid = true
					else
						if info.Creator and tostring(info.Creator.CreatorTargetId) == tostring(game.CreatorId) then
							isValid = true
						end
					end

					if isValid then
						local pName = info.Name or "Unknown Game"
						local iconId = (info.IconImageAssetId and info.IconImageAssetId > 0) and info.IconImageAssetId or pId
						local thumbUrl = "rbxthumb://type=Asset&id=" .. iconId .. "&w=150&h=150"
						
						if CurrentGameTabToken == myToken then
							CreateGameCard(pId, pName, thumbUrl)
							count = count + 1
						end
					end
				end
			end)
			task.wait(0.02)
		end

		task.wait(2.5)
		if CurrentGameTabToken == myToken then
			if count > 0 then
				GamesStatusText.Visible = false
			else
				GamesStatusText.Text = "No Mini-Games or Portals found."
				GamesStatusText.Visible = true
			end
			IsGamesScanning = false
			GamesRefreshBtn.Text = "Refresh"
		end
	end)
end

