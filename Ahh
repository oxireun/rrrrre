local function StartMatrixEffect(container)
	task.spawn(function()
		while container.Parent do
			if not container.Visible and container.Name ~= "SplashMatrix" then task.wait(0.2) continue end
			local drop = Instance.new("TextLabel")
			drop.Text = math.random() > 0.5 and "0" or "1"
			drop.TextColor3 = Color3.fromRGB(150, 40, 255) 
			drop.TextTransparency = 0.6
			drop.BackgroundTransparency = 1
			drop.Size = UDim2.new(0, 20, 0, 20)
			drop.Position = UDim2.new(math.random(0, 100) / 100, 0, -0.1, 0)
			drop.Font = Enum.Font.Code
			drop.TextSize = math.random(14, 22)
			drop.ZIndex = container.ZIndex or 0
			drop.Parent = container
			
			local duration = math.random(3, 6)
			local tween = TweenService:Create(drop, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
				Position = UDim2.new(drop.Position.X.Scale, 0, 1.1, 0),
				TextTransparency = 1
			})
			tween:Play()
			tween.Completed:Connect(function() drop:Destroy() end)
			task.wait(0.12)
		end
	end)
end

