local FoundRemotes = {} 
local LoopingEvents = false
local LoopingFuncs = false
local ForceString = false

local function GetArguments()
	local text = ArgInput.Text
	local args = {}
	if text ~= "" then
		if ForceString then
			table.insert(args, tostring(text))
		else
			local numberValue = tonumber(text)
			if numberValue then table.insert(args, numberValue) else table.insert(args, text) end
		end
	end
	return args
end

local function FindScriptForRemote(remoteName)
	local foundPath = nil
	pcall(function()
		for _, v in pairs(getgc(true)) do
			if type(v) == "function" and islclosure(v) then
				local s, consts = pcall(debug.getconstants, v)
				if s and consts then
					for _, const in pairs(consts) do
						if const == remoteName then
							local env = getfenv(v)
							if env.script and typeof(env.script) == "Instance" then
								foundPath = env.script:GetFullName()
								return 
							end
						end
					end
				end
			end
		end
	end)
	return foundPath
end

