task.spawn(function()
	local filling = true
	
	task.spawn(function()
		while filling do
			TweenService:Create(LoadText, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {TextTransparency = 0.6}):Play()
			task.wait(0.5)
			if filling then
				TweenService:Create(LoadText, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {TextTransparency = 0}):Play()
				task.wait(0.5)
			end
		end
	end)

	task.spawn(function()
		while filling do
			BarGradient.Offset = Vector2.new(-1, 0)
			local gradTween = TweenService:Create(BarGradient, TweenInfo.new(0.8, Enum.EasingStyle.Linear), {Offset = Vector2.new(1, 0)})
			gradTween:Play()
			gradTween.Completed:Wait()
		end
	end)

	local shineActive = true
	task.spawn(function()
		while shineActive do
			ShineGradient.Offset = Vector2.new(-1, 0)
			local shineTween = TweenService:Create(ShineGradient, TweenInfo.new(1.2, Enum.EasingStyle.Linear), {Offset = Vector2.new(1, 0)})
			shineTween:Play()
			shineTween.Completed:Wait()
			task.wait(0.2)
		end
	end)
	
	task.spawn(function()
		local rot = 0
		while shineActive do
			rot = (rot + 2) % 360
			NeonGlow.Rotation = rot
			NeonGlow.ImageTransparency = 0.2 + (math.sin(tick() * 3) * 0.1)
			task.wait(0.02)
		end
	end)

	local loadTween = TweenService:Create(LoadBarFill, TweenInfo.new(2, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 1, 0)})
	loadTween:Play()
	loadTween.Completed:Wait()
	
	filling = false 
	shineActive = false
	SplashMatrix:Destroy()

	SplashFrame:Destroy()
	MainFrame.Visible = true
	MainFrame.Size = UDim2.new(0.65, 0, 0.75, 0)
	MainFrame:TweenSize(UDim2.new(0.65, 0, 0.94, 0), "Out", "Back", 0.4, true)
end)
