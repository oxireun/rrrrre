local function IsLinkedToUniverse(assetId)
	local s, res = pcall(function()
		return game:HttpGet("https://economy.roproxy.com/v2/assets/" .. tostring(assetId) .. "/details")
	end)
	if s and res then
		local ds, decoded = pcall(function() return HttpService:JSONDecode(res) end)
		if ds and decoded and decoded.SaleLocation and decoded.SaleLocation.UniverseIds then
			for _, uid in ipairs(decoded.SaleLocation.UniverseIds) do
				if tostring(uid) == tostring(game.GameId) then return true end
			end
		end
	end
	return false
end

-- KUSURSUZ GİZLİ VERİ TARAYICI (Regex ile tüm şifreli metinleri parçalar)
local function CollectInGameNumbers()
	local nums = {}
	
	local function extractIds(text)
		for match in string.gmatch(tostring(text), "%d+") do
			if #match >= 8 then
				local n = tonumber(match)
				if n and n > 10000000 then nums[n] = true end
			end
		end
	end

	local function scan(parent)
		local descendants = parent:GetDescendants()
		for i, v in ipairs(descendants) do
			if i % 1500 == 0 then task.wait() end 
			pcall(function()
				extractIds(v.Name)
				if v:IsA("StringValue") or v:IsA("IntValue") or v:IsA("NumberValue") then extractIds(v.Value) end
				for _, attrVal in pairs(v:GetAttributes()) do extractIds(attrVal) end
				if v:IsA("ProximityPrompt") then 
					extractIds(v.ObjectText) 
					extractIds(v.ActionText) 
				end
				if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then extractIds(v.Text) end
			end)
		end
	end
	
	pcall(function() scan(game:GetService("Workspace")) end)
	pcall(function() scan(game:GetService("ReplicatedStorage")) end)
	pcall(function() scan(LocalPlayer:WaitForChild("PlayerGui")) end)
	
	pcall(function()
		local gc = getgc(true)
		for i, v in ipairs(gc) do
			if i % 2000 == 0 then task.wait() end
			if type(v) == "function" and islclosure(v) then
				local s, consts = pcall(debug.getconstants, v)
				if s and consts then
					for _, c in pairs(consts) do
						extractIds(c)
					end
				end
			end
		end
	end)
	return nums
end

local CurrentUGCTabToken = 0
local IsUGCScanning = false
local UGCsLoaded = false

local function LoadUGCsData(forceRefresh)
	if UGCsLoaded and not forceRefresh then return end
	if IsUGCScanning then return end
	IsUGCScanning = true
	UGCsLoaded = true
	
	CurrentUGCTabToken = CurrentUGCTabToken + 1
	local myToken = CurrentUGCTabToken
	
	ItemsRefreshBtn.Text = "Scanning..."
	for _, v in pairs(UGCScrollContainer:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
	StatusText.Text = "Checking Universal API for " .. UGCCurrentFilter .. " UGCs..."
	StatusText.Visible = true
	
	local creatorId = game.CreatorId
	local creatorType = game.CreatorType == Enum.CreatorType.Group and "Group" or "User"
	local shortGameName = string.sub(game.Name, 1, 15)
	local universeId = game.GameId
	local placeId = game.PlaceId
	
	local url1 = "https://catalog.roproxy.com/v1/search/items?category=All&creatorTargetId="..creatorId.."&creatorType="..creatorType.."&sortType=Updated&sortOrder=Desc&limit=120"
	local url2 = "https://catalog.roproxy.com/v1/search/items?category=All&keyword="..HttpService:UrlEncode(shortGameName).."&sortType=Updated&sortOrder=Desc&limit=60"
	local url3 = "https://catalog.roproxy.com/v1/search/items?category=All&keyword="..tostring(universeId).."&sortType=Updated&sortOrder=Desc&limit=60"
	local url4 = "https://catalog.roproxy.com/v1/search/items?category=All&keyword="..tostring(placeId).."&sortType=Updated&sortOrder=Desc&limit=60"
	
	task.spawn(function()
		local inGameNums = CollectInGameNumbers()
		local itemsToProcess = {}
		local addedIds = {}
		
		local function fetchURL(url)
			local s, res = pcall(function() return game:HttpGet(url) end)
			if CurrentUGCTabToken ~= myToken then return end
			if s and res and type(res) == "string" then
				local ds, decoded = pcall(function() return HttpService:JSONDecode(res) end)
				if ds and decoded and decoded.data then
					for _, item in ipairs(decoded.data) do
						if not addedIds[item.id] then
							addedIds[item.id] = true
							item.fromAPI = true
							table.insert(itemsToProcess, item)
						end
					end
				end
			end
		end

		fetchURL(url1)
		fetchURL(url2)
		fetchURL(url3)
		fetchURL(url4)
		
		for id, _ in pairs(inGameNums) do
			if not addedIds[id] then
				addedIds[id] = true
				table.insert(itemsToProcess, {id = id, itemType = "Asset", fromAPI = false})
			end
		end
		
		if CurrentUGCTabToken ~= myToken then IsUGCScanning = false return end
		StatusText.Visible = false
		
		local foundCount = 0
		
		for _, item in ipairs(itemsToProcess) do
			task.spawn(function()
				if CurrentUGCTabToken ~= myToken then return end
				
				local isBundle = (item.itemType == "Bundle")
				local infoType = isBundle and Enum.InfoType.Bundle or Enum.InfoType.Asset
				
				local success, info = pcall(function() 
					return MarketplaceService:GetProductInfo(item.id, infoType) 
				end)
				
				if success and info then
					local allowedTypes = {[8]=true,[41]=true,[42]=true,[43]=true,[44]=true,[45]=true,[46]=true,[47]=true,[64]=true,[65]=true,[66]=true,[67]=true,[68]=true,[69]=true,[70]=true,[71]=true,[72]=true}
					local isAccessoryOrBundle = isBundle or allowedTypes[info.AssetTypeId]
					
					if isAccessoryOrBundle then
						
						local isLimited = info.IsLimited or info.IsLimitedUnique
						local isSameCreator = false
						if info.Creator and tostring(info.Creator.CreatorTargetId) == tostring(creatorId) then
							isSameCreator = true
						end
						
						local price = info.PriceInRobux
						local isFree = (price == 0)
						local isPaid = (price ~= nil and price > 0)
						
						if price == nil then
							if info.IsForSale == false and string.find((info.Description or ""):lower(), "free") then
								isFree = true
							else isPaid = true end
						end
						
						local itemCreatorType = info.Creator and info.Creator.CreatorType or ""
						local itemCreatorId = info.Creator and tostring(info.Creator.CreatorTargetId) or ""
						local passFilter = false

						if UGCCurrentFilter == "Free" and isFree then passFilter = true
						elseif UGCCurrentFilter == "Paid" and isPaid then passFilter = true
						elseif UGCCurrentFilter == "Creator" and itemCreatorType == "User" and itemCreatorId == tostring(game.CreatorId) then passFilter = true
						elseif UGCCurrentFilter == "Group" and itemCreatorType == "Group" and itemCreatorId == tostring(game.CreatorId) then passFilter = true end
						
						local isConfirmed = false
						if UGCCurrentFilter == "Free" or UGCCurrentFilter == "Paid" then
							if inGameNums[item.id] then isConfirmed = true 
							elseif item.fromAPI then
								local desc = info.Description or ""
								local name = info.Name or ""
								if string.find(desc, tostring(game.PlaceId)) or string.find(desc, tostring(game.GameId)) then isConfirmed = true
								elseif isLimited and isSameCreator then isConfirmed = true
								elseif #game.Name > 4 and string.find(name:lower(), string.sub(game.Name:lower(), 1, 10)) then isConfirmed = true
								else
									if IsLinkedToUniverse(item.id) then isConfirmed = true end
								end
							end
						else isConfirmed = true end
						
						if isConfirmed and passFilter then
							foundCount = foundCount + 1
							local finalPrice = price or 0
							local stock = info.Remaining
							if not isLimited then stock = "Unlimited" elseif stock == nil or stock == "" then stock = "Unlimited" end
							local statusText = info.IsForSale and "Onsale" or "Offsale"
							local priceText = isFree and "Free" or (tostring(finalPrice) .. " R$")
							local extraText = statusText .. " | " .. priceText .. " | Stock: " .. tostring(stock)
							
							if CurrentUGCTabToken == myToken then
								CreateUGCBadgeCard(UGCScrollContainer, isBundle and "Bundle" or "UGC", item.id, info.Name or item.name or "Unknown", extraText)
							end
						end
					end
				end
			end)
			task.wait(0.02) 
		end
		
		task.wait(2.5) 
		if CurrentUGCTabToken == myToken then
			if foundCount == 0 then
				StatusText.Text = "No " .. UGCCurrentFilter .. " UGCs found."
				StatusText.Visible = true
			end
			IsUGCScanning = false
			ItemsRefreshBtn.Text = "Refresh"
		end
	end)
end

