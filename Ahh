local function Serialize(val, indent)
	local t = typeof(val)
	local indentStr = string.rep("    ", indent)
	local nextIndentStr = string.rep("    ", indent + 1)
	
	if t == "string" then return string.format('"%s"', val:gsub('"', '\\"'):gsub("\n", "\\n"))
	elseif t == "number" or t == "boolean" then return tostring(val)
	elseif t == "Instance" then return FormatPath(val)
	elseif t == "EnumItem" then return tostring(val)
	elseif t == "table" then
		local str = "{\n"
		for k, v in pairs(val) do
			local keyStr = ""
			if type(k) == "number" then keyStr = "[" .. k .. "]"
			elseif type(k) == "string" then keyStr = '["' .. k .. '"]'
			else keyStr = '["' .. tostring(k) .. '"]' end
			str = str .. nextIndentStr .. keyStr .. " = " .. Serialize(v, indent + 1) .. ";\n"
		end
		str = str .. indentStr .. "}"
		return str
	else return "nil --[[" .. t .. "]]" end
end

